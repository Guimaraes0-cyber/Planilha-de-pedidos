<?xml version="1.0" encoding="UTF-8"?>
<!--
  web.config para IIS
  ====================
  Coloque este arquivo dentro da pasta "dist" (gerada por "npm run build"),
  junto com index.html e a pasta assets/.

  Ele faz duas coisas:
  1. Redireciona qualquer rota da SPA (Vue Router) para index.html, senão o
     F5 numa página como /loja/RM dá erro 404 no IIS.
  2. Encaminha as chamadas /api/* para o backend Spring Boot, que roda
     como um processo Java separado (veja DEPLOY.md).

  PRÉ-REQUISITO no IIS: módulos "URL Rewrite" e "Application Request Routing (ARR)"
  precisam estar instalados (Web Platform Installer ou download direto da Microsoft).
  Depois de instalar o ARR, é preciso habilitar o proxy uma vez em:
  IIS Manager > (nível do servidor) > Application Request Routing Cache > Server Proxy Settings > Enable proxy
-->
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <!-- 1) Encaminha /api/* pro backend Spring Boot na porta 8080 -->
        <rule name="Proxy para API Spring Boot" stopProcessing="true">
          <match url="^api/(.*)" />
          <action type="Rewrite" url="http://localhost:8080/api/{R:1}" />
        </rule>

        <!-- 2) Qualquer outra rota que não seja um arquivo/pasta real vai pro index.html (SPA) -->
        <rule name="SPA fallback para index.html" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="/index.html" />
        </rule>
      </rules>
    </rewrite>

    <!-- Tipos MIME corretos pros arquivos gerados pelo Vite, caso o IIS não reconheça -->
    <staticContent>
      <remove fileExtension=".json" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
    </staticContent>

    <httpErrors errorMode="Detailed" />
  </system.webServer>
</configuration>
